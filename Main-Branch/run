clear

usage() {
	echo "Usage: ./run [-h show this menu] [-m start main.py] [-t start test.py] [-i test inventory] "
	exit 1
}


while getopts "hmti" opt; do
	case ${opt} in
		h)
			usage
			;;
		m)
			python3 main.py
			;;
		t)
			python3 test.py
			;;
		i)
			python3 inventory.py
			;;
		*)
			usage
			;;
	esac
done

shift $((OPTIND -1))

exit 1
